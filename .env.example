NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=CivicShield AI
NODE_ENV=development
BETTER_AUTH_SECRET=replace-with-long-random-secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/civicshield
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile
ENCRYPTION_KEY=replace-with-32-byte-base64-or-hex-key
RETRIEVAL_TIMEOUT_MS=5000
RETRIEVAL_MAX_BYTES=60000
RETRIEVAL_CACHE_TTL_MS=300000
REVIEWER_EMAIL_ALLOWLIST=
REVIEW_AUDIT_PAGE_SIZE=20
REVIEWER_MANAGEMENT_PAGE_SIZE=20
