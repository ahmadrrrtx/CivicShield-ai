# CivicShield AI local runtime configuration
# Copy this file to `.env.local` before running the app.

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=CivicShield AI
NODE_ENV=development

# Generate secure local secrets with:
# node scripts/generate-local-secrets.mjs
BETTER_AUTH_SECRET=replace-with-generated-secret
ENCRYPTION_KEY=replace-with-generated-secret

# Local PostgreSQL example
# Update if your local credentials/port differ.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/civicshield

# Optional for chat verification
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile

RETRIEVAL_TIMEOUT_MS=5000
RETRIEVAL_MAX_BYTES=60000
RETRIEVAL_CACHE_TTL_MS=300000
AI_PROVIDER_TIMEOUT_MS=15000
REVIEWER_EMAIL_ALLOWLIST=
REVIEW_AUDIT_PAGE_SIZE=20
REVIEWER_MANAGEMENT_PAGE_SIZE=20
